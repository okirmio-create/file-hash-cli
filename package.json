{
  "name": "file-hash-cli",
  "version": "1.0.0",
  "description": "Calculate file hashes (MD5, SHA1, SHA256, SHA512) from the command line",
  "type": "module",
  "bin": {
    "file-hash": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hash",
    "md5",
    "sha1",
    "sha256",
    "sha512",
    "checksum",
    "file",
    "cli"
  ],
  "author": "okirmio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/okirmio-create/file-hash-cli"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "@types/node": "^22.12.0"
  },
  "engines": {
    "node": ">=18"
  }
}
